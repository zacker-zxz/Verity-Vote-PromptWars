# VoteGuide AI — Environment Variables
# Copy this file to .env.local and fill in your keys

# Google Gemini API Key (for AI chat assistant)
GEMINI_API_KEY=

# Google Maps API Key (for polling center discovery)
GOOGLE_MAPS_API_KEY=

# Google Cloud Translation API Key (for multilingual support)
GOOGLE_TRANSLATE_API_KEY=

# Optional: Google OAuth Client ID (for sign-in)
GOOGLE_CLIENT_ID=

# Optional: Firestore project ID (for persistent storage)
FIRESTORE_PROJECT_ID=
